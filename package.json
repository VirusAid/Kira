{
  "name": "kira",
  "version": "1.0.0",
  "description": "Kira — персональный ИИ-ассистент нового поколения для Windows",
  "main": "./out/main/index.js",
  "author": "VirusAid (D3F0LT)",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "electron-vite build && electron-builder --win",
    "test:core": "esbuild tests/core.test.ts --bundle --platform=node --format=cjs --alias:electron=./tests/electron-stub.js --outfile=tests/.build/test-core.cjs && node tests/.build/test-core.cjs",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "dist:standalone": "node scripts/prepare-standalone.mjs && electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "mammoth": "^1.12.0",
    "marked": "^12.0.2",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "telegram": "^2.26.22",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.436.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "zustand": "^4.5.5"
  },
  "build": {
    "appId": "app.kira.assistant",
    "productName": "Kira",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "."
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
